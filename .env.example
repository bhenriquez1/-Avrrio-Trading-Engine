# ---------------------------------------------------------------------------
# Avrrio Trading Engine — environment configuration
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# All trading-related flags default to the SAFE value.
# ---------------------------------------------------------------------------

# --- TopstepX / ProjectX API ---
# Connect your PRACTICE account first. Auth method: ProjectX loginKey
# (TOPSTEP_USERNAME + TOPSTEP_API_KEY -> session token). Password / account name
# are accepted for account selection but loginKey only needs username + API key.
# Use POST /api/topstepx/auth-test (or the dashboard "Auth test" button) to see
# exactly which variables are missing or invalid.
TOPSTEP_MODE=practice
TOPSTEP_API_BASE_URL=https://api.topstepx.com
TOPSTEP_USERNAME=
TOPSTEP_PASSWORD=
TOPSTEP_API_KEY=
TOPSTEP_ACCOUNT_NAME=
TOPSTEP_ACCOUNT_ID=

# --- AI analysis / consensus ---
# At least Claude is recommended. OpenAI + TradeGPT enable 2-of-3 consensus.
ANTHROPIC_API_KEY=
AVRRIO_CLAUDE_MODEL=claude-opus-4-8
OPENAI_API_KEY=
AVRRIO_OPENAI_MODEL=gpt-4o
# Optional third opinion ("TradeGPT" or any OpenAI-compatible endpoint).
TRADEGPT_API_KEY=
TRADEGPT_BASE_URL=
TRADEGPT_MODEL=gpt-4o-mini
# Min consensus confidence (0..1) required for semi-autonomous auto-execution.
AVRRIO_CONFIDENCE_THRESHOLD=0.9

# --- Optional news source (deterministic high-impact-news guard) ---
# A URL returning JSON: [{ "title", "time" (ISO), "impact": "high", "symbols": [] }]
NEWS_API_URL=

# --- Execution flags (DEFAULT SAFE) ---
# Master switch for sending real orders. Approvals are paper until this is true.
LIVE_TRADING_ENABLED=false
# Allow auto-execution when EVERY safety gate passes.
SEMI_AUTONOMOUS_ENABLED=false

# --- Safety limits ---
# Emergency kill switch. When true, ALL trading is blocked (cannot be cleared
# at runtime while this env value is true).
KILL_SWITCH=false
# Daily realized+unrealized loss cap (USD) before new trades are blocked.
DAILY_MAX_LOSS=1000
# Largest position (contracts) any single order may request.
MAX_POSITION_SIZE=2
# Maximum number of trades per calendar day.
MAX_TRADES_PER_DAY=2
# Hard cap on dollar risk for a single trade (0 = policy only).
MAX_RISK_PER_TRADE=300

# --- Dashboard ---
# Password required to sign in and approve trades. Set this before exposing it.
DASHBOARD_PASSWORD=
# Local port. On Render/PaaS, PORT is injected and takes precedence.
DASHBOARD_PORT=4317

# --- Pre-approved trade queue ---
# Public URL used to build approve/reject links in phone notifications.
# Set this to your deployed URL (e.g. https://avrrio.onrender.com).
PUBLIC_BASE_URL=http://localhost:4317
# A recommendation expires (auto-cancels) if not approved within this many minutes.
NOTIFICATION_EXPIRY_MINUTES=5
# How close the last price must get to the entry (fraction) to trigger a
# pre-approved trade. 0.001 = 0.1%.
EXEC_TRIGGER_TOLERANCE_PCT=0.001

# --- Phone / alert notifications ---
# Master switch. When off, no alerts are sent.
PHONE_NOTIFICATIONS_ENABLED=false

# Email (enabled by default; only sends when a SendGrid key + recipient are set).
EMAIL_NOTIFICATIONS_ENABLED=true
NOTIFICATION_EMAIL_TO=
NOTIFICATION_EMAIL_FROM=alerts@avrrio.local
SENDGRID_API_KEY=

# Telegram (recommended first channel — fast and free).
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMS via Twilio (build/test this first per the roadmap).
SMS_ENABLED=false
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Authorized number for alerts AND inbound approve/reject replies.
ALERT_PHONE_NUMBER=
# Legacy alias for ALERT_PHONE_NUMBER (optional).
BRIAN_PHONE_NUMBER=
# Avrrio Score at/above which a scanner opportunity triggers an SMS alert.
AVRRIO_ALERT_SCORE=85

# --- Scheduled opportunity scanner (Phase 1) ---
# Master switch for the recurring scanner. Default off; alerts only fire for
# qualifying setups (no noise). Turn on once SMS is configured.
SCHEDULED_SCANNER_ENABLED=false
# Scan cadence in minutes.
SCAN_INTERVAL_MINUTES=20
# Minimum reward/risk to alert (with AVRRIO_ALERT_SCORE this is the quality bar).
AVRRIO_MIN_RR=2
# Max alerts per cycle — keep it to the best 1-3 ideas, not every signal.
AVRRIO_MAX_ALERTS=3
# Local hour (0-23) to text the daily summary; -1 disables.
DAILY_SUMMARY_HOUR=-1

# Twilio inbound webhook (set in the Twilio console to POST here):
#   https://YOUR_PUBLIC_URL/api/alerts/sms/inbound
