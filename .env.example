# ---------------------------------------------------------------------------
# Avrrio Trading Engine — environment configuration
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# --- TopstepX / ProjectX API (read-only usage in this phase) ---
# Base URL for the ProjectX gateway. Confirm the exact host in your TopstepX
# API settings (the "Add API Key" / ProjectX linking screen).
TOPSTEP_API_BASE_URL=https://api.topstepx.com
# Your ProjectX username (the account the API key is linked to).
TOPSTEP_USERNAME=
# The API key generated from the TopstepX API tab.
TOPSTEP_API_KEY=

# --- Claude (Anthropic) analysis service ---
# Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=
# Model used for analysis / risk reasoning. Defaults to the latest Opus.
AVRRIO_CLAUDE_MODEL=claude-opus-4-8

# --- Engine safety switches ---
# Hard kill-switch for any order placement. MUST stay "false" in this phase.
# The code refuses to place live orders regardless, but this is belt-and-suspenders.
AVRRIO_ALLOW_LIVE_ORDERS=false

# --- Dashboard ---
DASHBOARD_PORT=4317
