{
  "name": "avrrio-trading-engine",
  "version": "0.1.0",
  "description": "Read-only TopstepX/ProjectX trading analyst + AI risk manager. No live order placement.",
  "type": "module",
  "main": "dist/src/server.js",
  "scripts": {
    "build": "tsc && node scripts/copy-assets.mjs",
    "start": "node dist/src/server.js",
    "cli": "node dist/src/index.js",
    "dev": "tsx watch src/index.ts",
    "dashboard": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import tsx ./test/*.test.ts"
  },
  "keywords": [
    "trading",
    "topstep",
    "projectx",
    "risk-management",
    "claude",
    "futures"
  ],
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.105.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
